# ══════════════════════════════════════════════════════════
# GerenciaX API — .gitignore
# ══════════════════════════════════════════════════════════

# ── Dependencies ───────────────────────────────────────────
node_modules/

# ── Build output ───────────────────────────────────────────
dist/
build/

# ── Environment ────────────────────────────────────────────
.env
.env.dev
.env.prod
.env.local
.env.*.local

# ── IDE / Editor ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ── Test / Coverage ────────────────────────────────────────
coverage/
.nyc_output/

# ── Drizzle ────────────────────────────────────────────────
drizzle/meta/

# ── Misc ───────────────────────────────────────────────────
*.tsbuildinfo
